{
    "openapi": "3.0.0",
    "info": {
        "title": "Site API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://api.local",
            "description": "Local HTTPS server"
        }
    ],
    "paths": {
        "/api/health": {
            "get": {
                "tags": [
                    "System"
                ],
                "summary": "API health check",
                "operationId": "apiHealth",
                "responses": {
                    "200": {
                        "description": "Application is healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/whois": {
            "get": {
                "tags": [
                    "Whois"
                ],
                "summary": "Check domain availability and fetch WHOIS data",
                "operationId": "apiWhoisLookup",
                "parameters": [
                    {
                        "name": "domain",
                        "in": "query",
                        "description": "Domain name to check, for example: example.com",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "google.com"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Whois lookup result",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "domain": {
                                            "type": "string",
                                            "example": "google.com"
                                        },
                                        "available": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "info": {
                                            "type": "object",
                                            "nullable": true,
                                            "additionalProperties": {
                                                "type": "string"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "nullable": true
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The domain field is required."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "tags": [
        {
            "name": "System",
            "description": "System"
        },
        {
            "name": "Whois",
            "description": "Whois"
        }
    ]
}